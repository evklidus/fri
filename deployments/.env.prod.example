# Production environment template.
#
# USAGE:
#   cp .env.prod.example .env
#   # then fill in the secrets below
#
# Never commit the real .env to git — it's in .gitignore.

# ── Domain / public hostname ──────────────────────────────────────────────
# Your domain (no protocol, no www). Cloudflare handles HTTPS at the edge,
# Caddy here listens on plain HTTP :80 and proxies to the Go app.
#   PUBLIC_HOSTNAME=footballreputation.ru
PUBLIC_HOSTNAME=

# ── Database ──────────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 24
POSTGRES_PASSWORD=

# ── External APIs ─────────────────────────────────────────────────────────
# Same keys as your local .env. Copy them over.
API_FOOTBALL_KEY=
YOUTUBE_API_KEY=
MEDIASTACK_API_KEY=

# These have sensible defaults — only set if you need to override:
# API_FOOTBALL_BASE_URL=https://v3.football.api-sports.io
# YOUTUBE_BASE_URL=https://www.googleapis.com/youtube/v3
# MEDIASTACK_BASE_URL=http://api.mediastack.com/v1
