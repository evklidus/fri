# Production environment template.
#
# USAGE:
#   cp .env.prod.example .env
#   # then fill in the secrets below
#
# Never commit the real .env to git — it's in .gitignore.

# ── Domain / public hostname ──────────────────────────────────────────────
# Either a real domain (Caddy will fetch a Let's Encrypt cert):
#   PUBLIC_HOSTNAME=fri.example.com
# Or your server IP (HTTP-only, no TLS — only for the first hours after
# deploy, before DNS points at the server):
#   PUBLIC_HOSTNAME=89.111.222.33
PUBLIC_HOSTNAME=

# Email used by Let's Encrypt to send certificate-renewal warnings.
# Optional but recommended.
ACME_EMAIL=

# ── Database ──────────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 24
POSTGRES_PASSWORD=

# ── External APIs ─────────────────────────────────────────────────────────
# Same keys as your local .env. Copy them over.
API_FOOTBALL_KEY=
YOUTUBE_API_KEY=
MEDIASTACK_API_KEY=

# These have sensible defaults — only set if you need to override:
# API_FOOTBALL_BASE_URL=https://v3.football.api-sports.io
# YOUTUBE_BASE_URL=https://www.googleapis.com/youtube/v3
# MEDIASTACK_BASE_URL=http://api.mediastack.com/v1
