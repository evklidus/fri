# Caddy reverse-proxy config for the FRI demo deployment.
#
# Topology:
#
#   Visitor (IPv4) ‚îÄ‚îÄHTTPS‚îÄ‚îÄ‚ñ∫ Cloudflare ‚îÄ‚îÄHTTP‚îÄ‚îÄ‚ñ∫ Caddy ‚îÄ‚îÄ‚ñ∫ Go app
#                              ‚îÇ Universal SSL    ‚îÇ this   :8080
#                              ‚îÇ DDoS shield      ‚îÇ file
#                              ‚îî IPv4‚ÜîIPv6 bridge
#
# Cloudflare terminates TLS at the edge with their free Universal SSL cert,
# so Caddy here only listens on plain HTTP :80. The CF Free plan also
# bridges IPv4 visitors to our IPv6-only origin ‚Äî the whole reason CF is
# in this stack.
#
# Why HTTP at the origin (not HTTPS):
#   - CF SSL/TLS mode "Flexible" ‚Üí CF talks HTTP to origin.
#   - No ACME challenge to manage, no cert renewal, no port 443.
#   - Trade-off: traffic between CF and origin is not encrypted. For this
#     demo the threat model is acceptable. Upgrade path: switch CF to
#     "Full (Strict)" + install a CF Origin Certificate later.

# Listen on port 80 only. Hostname is bound to PUBLIC_HOSTNAME from .env so
# the same config works for any domain. The `http://` prefix tells Caddy
# to NOT auto-issue a Let's Encrypt cert (default behaviour for bare names).
http://{$PUBLIC_HOSTNAME}, http://www.{$PUBLIC_HOSTNAME} {
	# Reverse-proxy to the Go app. `app` resolves via docker DNS.
	reverse_proxy app:8080 {
		# CF passes the real visitor IP in `CF-Connecting-IP`. Forward it
		# as X-Real-IP / X-Forwarded-For so the Go app's voting rate-
		# limiter (which already reads those headers via gin) sees unique
		# visitor IPs instead of CF's edge PoP IP.
		header_up X-Real-IP {http.request.header.CF-Connecting-IP}
		header_up X-Forwarded-For {http.request.header.CF-Connecting-IP}
	}

	# Cheap security headers. Nothing breaks the demo.
	header {
		# Don't allow MIME sniffing.
		X-Content-Type-Options "nosniff"
		# Block clickjacking via iframe.
		X-Frame-Options "DENY"
		# Don't leak referer when users click out to news article links.
		Referrer-Policy "strict-origin-when-cross-origin"
		# Hide default `Server: Caddy` banner.
		-Server
	}

	# Compress text responses. CF will cache the gzipped copy.
	encode zstd gzip

	# Access log to stdout ‚Äî captured by docker logs.
	log {
		output stdout
		format console
		level INFO
	}
}
